+std::string format_size(int size) {
+    if (size >= 1000000) {
+        return std::to_string(size / 1000000) + "M";
+    }
+    if (size >= 1000) {
+        return std::to_string(size / 1000) + "K";
+    }
+    return std::to_string(size);
+}
+
+std::string format_integer(int64_t value) {
+    std::string digits = std::to_string(value);
+    std::string formatted;
+    const int first_group = static_cast<int>(digits.size()) % 3;
+    if (first_group > 0) {
+        formatted.append(digits.substr(0, first_group));
+        if (digits.size() > static_cast<size_t>(first_group)) {
+            formatted.push_back(' ');
+        }
+    }
+    for (size_t i = first_group; i < digits.size(); i += 3) {
+        formatted.append(digits.substr(i, 3));
+        if (i + 3 < digits.size()) {
+            formatted.push_back(' ');
+        }
+    }
+    return formatted.empty() ? digits : formatted;
+}
+
+void set_status(const std::string& status) {
+    std::lock_guard<std::mutex> lock(g_status_mutex);
+    g_status = status;
+}
+
+std::string get_status() {
+    std::lock_guard<std::mutex> lock(g_status_mutex);
+    return g_status;
+}
+
+std::string format_time(double time_us) {
+    std::ostringstream out;
+    out << std::fixed << std::setprecision(2);
+    if (time_us >= 1000.0) {
+        out << (time_us / 1000.0) << " ms";
+    } else {
+        out << time_us << " us";
+    }
+    return out.str();
+}
+
+double compute_plot_max(const std::vector<double>& values) {
+    if (values.empty()) {
+        return 1.0;
+    }
+    const double max_value = *std::max_element(values.begin(), values.end());
+    return max_value > 0.0 ? max_value * 1.12 : 1.0;
+}
+
+double average(const std::vector<double>& samples) {
+    if (samples.empty()) {
+        return 0.0;
+    }
+    const double sum = std::accumulate(samples.begin(), samples.end(), 0.0);
+    return sum / static_cast<double>(samples.size());
+}
